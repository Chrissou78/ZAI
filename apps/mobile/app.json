{
  "expo": {
    "name": "ZAI Experience Club",
    "slug": "zai-experience-club",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "zai",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ch.zai.experienceclub",
      "infoPlist": {
        "NSCameraUsageDescription": "ZAI needs camera access to take photos of purchase receipts for product claims."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "ch.zai.experienceclub",
      "permissions": ["CAMERA"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ZAI to access your camera to photograph purchase receipts."
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://zai-chi.vercel.app/api",
      "companyId": "p7IH5cVirHbWy1a0hPxeKro5j9bRSJtt",
      "wallettwoUrl": "https://wallet.wallettwo.com/auth/login",
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}