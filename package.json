{
  "name": "zai-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "axios": "^1.6.0",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.3",
    "otplib": "^13.4.0",
    "pg": "^8.13.0",
    "stripe": "^22.3.0"
  },
  "scripts": {
    "dev": "pnpm --filter zai-frontend dev",
    "build": "cd apps/frontend && pnpm exec vite build",
    "start": "node server.js",
    "mobile": "pnpm --filter zai-mobile start",
    "mobile:ios": "pnpm --filter zai-mobile ios",
    "mobile:android": "pnpm --filter zai-mobile android"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.1"
  }
}
