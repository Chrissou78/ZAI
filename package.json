{
  "name": "zai-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "frontend": "cd apps/frontend && pnpm dev",
    "backend": "cd apps/backend && pnpm dev",
    "frontend:build": "cd apps/frontend && pnpm build",
    "backend:build": "cd apps/backend && pnpm build"
  },
  "pnpm": {
    "overrides": {}
  }
}